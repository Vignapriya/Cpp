#include<iostream>
using namespace std;
class binary
{
   int decimal,size,temp;
   public:
   binary()
   {
      decimal=0;
      size=0;
   }
   void getinput()
   {
      cout<<"enter a number:"<<endl;
      cin>>decimal;
   }
      void getsize()
      {
         size=0;
         temp=decimal;
         while(temp>0)
         {
            temp/=2;
            size++;
         }
      }
      void store()
      {
         int*bin=new int[size];
         int index=size-1;
         int num=decimal;
         while(num>0)
         {
            bin[index--]=num%2;
            num/=2;
         }
            cout<<"binary: ";
            for(int i=0;i<size;i++)
            {
               cout<<bin[i];
            }

      }
};
int main()
{
binary b1;
b1.getinput();
b1.getsize();
b1.store();
return 0;
}
